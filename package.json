{
  "name": "nixparse",
  "version": "0.1.0",
  "description": "Type-safe parsers for Unix command output (ps, df, du, free, lsof, mount, who, uptime, ip, ss) with runtime validation via Zod",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "parser",
    "unix",
    "ps",
    "df",
    "du",
    "free",
    "lsof",
    "mount",
    "uptime",
    "ip",
    "ss",
    "zod",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
